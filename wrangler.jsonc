// wrangler.jsonc
{
    "name": "pizza-store",
    "main": "./src/main.jsx",
    "compatibility_date": "2024-04-03",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS"
    },
    "vars": {
        "VITE_API_BASE_URL": "https://palladiumacaiapi.runasp.net/AcaiAPI"
    }
}
